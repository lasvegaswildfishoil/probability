                noiseNode.loop = true;
                const filter = aCtx.createBiquadFilter();
                filter.type = 'bandpass'; filter.frequency.value = 3200; filter.Q.value = 1.2;
                noiseGain = aCtx.createGain(); noiseGain.gain.value = 0;
                noiseNode.connect(filter); filter.connect(noiseGain); noiseGain.connect(aCtx.destination);
                noiseNode.start();
            }
            if (aCtx.state === 'suspended') aCtx.resume();
        }


        function setScratchSound(volume) {
            if (!noiseGain) return;
            noiseGain.gain.setTargetAtTime(volume * 0.15, aCtx.currentTime, 0.01);
        }


        function playPrizeSound(winAmount, isMajor = false) {
            try {
                ensureAudioContext();
                const now = aCtx.currentTime;
                if(winAmount > 0) {
                    if (isMajor) {
                        [523.25, 659.25, 783.99, 1046.50, 1318.51].forEach((f, i) => {
                            const o = aCtx.createOscillator();
                            const g = aCtx.createGain();
                            o.type = i % 2 === 0 ? 'square' : 'triangle';
                            o.frequency.setValueAtTime(f, now + i * 0.1);
                            g.gain.setValueAtTime(0, now + i * 0.1);
                            g.gain.linearRampToValueAtTime(0.3, now + i * 0.1 + 0.02);
                            g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.1 + 0.7);
                            o.connect(g); g.connect(aCtx.destination);
                            o.start(now + i * 0.1); o.stop(now + i * 0.1 + 0.7);
                        });
                    } else {
                        [659.25, 880.00].forEach((f, i) => {
                            const o = aCtx.createOscillator();
                            const g = aCtx.createGain();
                            o.type = 'triangle';
                            o.frequency.setValueAtTime(f, now + i * 0.1);
                            g.gain.setValueAtTime(0, now + i * 0.1);
                            g.gain.linearRampToValueAtTime(0.25, now + i * 0.1 + 0.02);
                            g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.1 + 0.5);
                            o.connect(g); g.connect(aCtx.destination);
                            o.start(now + i * 0.1); o.stop(now + i * 0.1 + 0.5);
                        });
                    }
                } else {
                    const o = aCtx.createOscillator();
                    const g = aCtx.createGain();
                    o.type = 'sine';
                    o.frequency.setValueAtTime(110, now);
                    o.frequency.linearRampToValueAtTime(40, now + 0.3);
                    g.gain.setValueAtTime(0.05, now);
                    g.gain.linearRampToValueAtTime(0.001, now + 0.3);
                    o.connect(g); g.connect(aCtx.destination);
                    o.start(now); o.stop(now + 0.3);
                }
            } catch(e) { console.error("Sound error", e); }
        }


        class ScratchSimulator {
            constructor(containerId, isFinite) {
                this.isFinite = isFinite;
                this.container = document.getElementById(containerId);
                this.isDrawing = false; this.lastPoint = null; this.walletEnabled = false; this.startingCapital = 2000;
                this.initUI(); this.resetPool(); this.initChart(); this.initEvents(); this.updateDisplay();
                this.resetScratchArea(`GOT $${TICKET_PRICE}?\nBUY & SCRATCH!`);
            }


            initUI() {
                const temp = document.getElementById('sim-template').content.cloneNode(true);
                temp.querySelector('.mode-title').innerText = this.isFinite ? "FINITE POOL" : "IDEAL POOL";
                temp.querySelector('.mode-desc').innerText = this.isFinite ? "有限獎池模式" : "理想獎池模式";
               
                this.els = {
                    canvas: temp.querySelector('.scratchCanvas'),
                    grid: temp.querySelector('.prize-grid'),
                    msg: temp.querySelector('.result-message'),
                    buyBtn: temp.querySelector('.buyBtn'),
                    bulkBtn: temp.querySelector('.bulkBtn'),
                    resetBtn: temp.querySelector('.resetBtn'),
                    chartCanvas: temp.querySelector('.prizePieChart'),
                    overlay: temp.querySelector('.chart-overlay'),
                    statWin: temp.querySelector('.stat-win'),
                    statExpected: temp.querySelector('.stat-expected'),
                    statProfit: temp.querySelector('.stat-profit'),
                    scratchedInfo: temp.querySelector('.scratched-info'),
                    rulesGrid: temp.querySelector('.rules-grid'),
                    prizeEv: temp.querySelector('.prize-ev-val'),
                    profitEv: temp.querySelector('.profit-ev-val'),
                    walletToggle: temp.querySelector('.walletToggle'),
                    walletContainer: temp.querySelector('.walletContainer'),
                    walletInput: temp.querySelector('.walletInput'),
                    statBalance: temp.querySelector('.stat-balance')
                };


                this.ctx = this.els.canvas.getContext('2d', { alpha: true });
                this.els.canvas.width = 660; this.els.canvas.height = 460;
                this.container.appendChild(temp);
            }


            resetPool() {
                this.stats = { totalCost: 0, totalWin: 0, scratched: 0, ruleCounts: RULES_CONFIG.map(() => 0), totalExpectedIncome: 0 };
                this.pool = [];
                if (this.isFinite) {
                    RULES_CONFIG.forEach((r, i) => { for(let j=0; j<r.baseCount; j++) this.pool.push(i); });
                    for (let i = this.pool.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [this.pool[i], this.pool[j]] = [this.pool[j], this.pool[i]];
                    }
                }
                this.isPurchased = false; this.isScratched = false;
                this.updateDisplay(); this.resetScratchArea("READY TO PLAY?\nTAP BUY!");
            }


            initChart() {
                this.chart = new Chart(this.els.chartCanvas, {
                    type: 'doughnut',
                    data: {
                        labels: RULES_CONFIG.map(r => r.name_en),
                        datasets: [{
                            data: RULES_CONFIG.map(r => r.baseCount),
                            backgroundColor: RULES_CONFIG.map(r => r.color),
                            borderWidth: 2, borderColor: '#1a1a1a'
                        }]
                    },
                    options: {
                        plugins: { legend: { display: false } },
                        cutout: '70%', responsive: true, maintainAspectRatio: true,
                        animation: { duration: 500 }
                    }
                });
            }


            getMousePos(e) {
                const rect = this.els.canvas.getBoundingClientRect();
                const p = e.touches ? e.touches[0] : e;
                return { x: (p.clientX - rect.left) * (660 / rect.width), y: (p.clientY - rect.top) * (460 / rect.height) };
            }


            initEvents() {
                this.els.buyBtn.onclick = () => { ensureAudioContext(); this.buy(); };
                this.els.bulkBtn.onclick = () => { ensureAudioContext(); this.bulk(); };
                this.els.resetBtn.onclick = () => this.resetPool();
                this.els.walletToggle.onchange = (e) => {
                    this.walletEnabled = e.target.checked;
                    this.els.walletContainer.classList.toggle('hidden', !this.walletEnabled);
                    this.updateDisplay();
                };
                this.els.walletInput.oninput = (e) => { this.startingCapital = parseFloat(e.target.value) || 0; this.updateDisplay(); };
               
                const start = (e) => { if(!this.isPurchased || this.isScratched) return; ensureAudioContext(); this.isDrawing = true; this.lastPoint = this.getMousePos(e); };
                const move = (e) => {
                    if(!this.isDrawing) return; e.preventDefault();
                    const cp = this.getMousePos(e);
                    this.ctx.globalCompositeOperation = 'destination-out';
                    this.ctx.lineWidth = 70; this.ctx.lineCap = 'round'; this.ctx.lineJoin = 'round';
                    this.ctx.beginPath(); this.ctx.moveTo(this.lastPoint.x, this.lastPoint.y); this.ctx.lineTo(cp.x, cp.y); this.ctx.stroke();
                    const dx = cp.x - this.lastPoint.x, dy = cp.y - this.lastPoint.y;
                    const speed = Math.sqrt(dx*dx + dy*dy);
                    setScratchSound(Math.min(speed / 25, 1));
                    this.lastPoint = cp; this.checkEnd();
                };
                const end = () => { if(this.isDrawing) { this.isDrawing = false; this.lastPoint = null; setScratchSound(0); } };
                this.els.canvas.addEventListener('mousedown', start);
                this.els.canvas.addEventListener('touchstart', start);
                window.addEventListener('mousemove', move);
                window.addEventListener('touchmove', move, { passive: false });
                window.addEventListener('mouseup', end);
                window.addEventListener('touchend', end);
            }


            checkEnd() {
                if (this.isScratched) return;
                const data = this.ctx.getImageData(0,0,660,460).data;
                let cleared = 0;
                for(let i=3; i<data.length; i+=1024) if(data[i]<128) cleared++;
                if(cleared / (data.length/1024) > 0.55) this.finalize(true);
            }


            calculateCurrentEV() {
                const remTotal = this.isFinite ? (TOTAL_TICKETS - this.stats.scratched) : TOTAL_TICKETS;
                if (remTotal <= 0) return 0;
                let currentEV = 0;
                RULES_CONFIG.forEach((r, i) => {
                    const rem = this.isFinite ? (r.baseCount - this.stats.ruleCounts[i]) : r.baseCount;
                    currentEV += (r.win * (rem / remTotal));
                });
                return currentEV;
            }


            buy() {
                if(this.isFinite && this.pool.length === 0) return;
                if (this.walletEnabled) {
                    if (this.startingCapital + (this.stats.totalWin - this.stats.totalCost) < TICKET_PRICE) return;
                }
                this.isPurchased = true; this.isScratched = false; this.els.buyBtn.disabled = true; this.clearChartEffect();
                this.stats.totalExpectedIncome += (this.calculateCurrentEV() - TICKET_PRICE);
               
                if(this.isFinite) this.currentIdx = this.pool.pop();
                else {
                    let rnd = Math.random() * TOTAL_TICKETS;
                    for(let i=0; i<RULES_CONFIG.length; i++) {
                        if(rnd < RULES_CONFIG[i].baseCount) { this.currentIdx = i; break; }
                        rnd -= RULES_CONFIG[i].baseCount;
                    }
                }
                this.lastTotalAtScratch = this.isFinite ? (TOTAL_TICKETS - this.stats.scratched) : TOTAL_TICKETS;
                this.lastRuleAtScratch = this.isFinite ? (RULES_CONFIG[this.currentIdx].baseCount - this.stats.ruleCounts[this.currentIdx]) : RULES_CONFIG[this.currentIdx].baseCount;
                this.stats.scratched++; this.stats.totalCost += TICKET_PRICE;
                this.renderGrid(this.currentIdx);
                this.ctx.globalCompositeOperation = 'source-over'; this.ctx.fillStyle = '#1e293b'; this.ctx.fillRect(0,0,660,460);
                this.ctx.fillStyle = "rgba(0,0,0,0.15)"; for(let i=0; i<1500; i++) { this.ctx.fillRect(Math.random()*660, Math.random()*460, 1.5, 1.5); }
                this.ctx.fillStyle = "#fff"; this.ctx.font = "900 42px 'Bangers'"; this.ctx.textAlign = "center"; this.ctx.fillText("SCRATCH CAREFULLY!", 330, 240);
                this.updateDisplay();
            }


            renderGrid(idx) {
                const s = [...SYMBOLS].sort(() => Math.random() - 0.5);
                let b = []; const n = RULES_CONFIG[idx].name_zh;
                if(n.includes("六同")) b = Array(6).fill(s[0]);
                else if(n.includes("五同一異")) b = [...Array(5).fill(s[0]), s[1]];
                else if(n.includes("三同三同")) b = [...Array(3).fill(s[0]), ...Array(3).fill(s[1])];
                else if(n.includes("四同二同")) b = [...Array(4).fill(s[0]), ...Array(2).fill(s[1])];
                else if(n.includes("六異")) b = s.slice(0, 6);
                else if(n.includes("四同二異")) b = [...Array(4).fill(s[0]), s[1], s[2]];
                else if(n.includes("二同二同二同")) b = [...Array(2).fill(s[0]), ...Array(2).fill(s[1]), ...Array(2).fill(s[2])];
                else if(n.includes("三同兩同一異")) b = [...Array(3).fill(s[0]), ...Array(2).fill(s[1]), s[2]];
                else b = [s[0], s[1], s[2], s[3], s[4], s[0]];
                this.els.grid.innerHTML = ""; this.els.grid.classList.remove('grayscale');
                b.sort(() => Math.random() - 0.5).forEach(it => {
                    const c = document.createElement('div'); c.className = "grid-cell";
                    c.innerHTML = `<img src="${it.src}" class="max-w-[75%] max-h-[75%] pointer-events-none">`;
                    this.els.grid.appendChild(c);
                });
            }


            finalize(isManual = false) {
                if (this.isScratched) return;
                this.isScratched = true; this.ctx.clearRect(0,0,660,460);
                setScratchSound(0);
                const r = RULES_CONFIG[this.currentIdx];
                this.stats.totalWin += r.win;
                this.stats.ruleCounts[this.currentIdx]++;
                if (r.win > 0) {
                    if (r.isMajor) {
                        const overlay = document.getElementById('jackpot-overlay');
                        overlay.style.display = 'block';
                        setTimeout(() => { overlay.style.display = 'none'; }, 3000);
                        playPrizeSound(r.win, true);
                        if(isManual) showWinnerModal(r);
                    } else {
                        playPrizeSound(r.win, false);
                    }
                } else {
                    playPrizeSound(0, false);
                }
                this.els.msg.innerHTML = r.win > 0 ? `<span class="animate-bounce">BOOM! $${r.win.toLocaleString()}</span>` : "OOPS... LOSE";
                this.showChartHighlight(this.currentIdx); this.updateDisplay(); this.els.buyBtn.disabled = false;
            }


            bulk() {
                const max = this.isFinite ? this.pool.length : 100;
                let cnt = max;
                if (this.walletEnabled) {
                    cnt = Math.min(max, Math.floor((this.startingCapital + this.stats.totalWin - this.stats.totalCost) / TICKET_PRICE));
                    if (cnt <= 0) { this.resetScratchArea("INSUFFICIENT FUNDS!"); return; }
                }
               
                let anyMajor = false;
                let anyPrize = false;


                for(let i=0; i<cnt; i++) {
                    this.stats.totalExpectedIncome += (this.calculateCurrentEV() - TICKET_PRICE);
                    let idx = this.isFinite ? this.pool.pop() : Math.floor(Math.random() * RULES_CONFIG.length);
                    const r = RULES_CONFIG[idx];
                    if (r.isMajor) anyMajor = true;
                    if (r.win > 0) anyPrize = true;
                    this.stats.scratched++; this.stats.totalCost += TICKET_PRICE; this.stats.totalWin += r.win; this.stats.ruleCounts[idx]++;
                }


                if (anyMajor) {
                    const overlay = document.getElementById('jackpot-overlay');
                    overlay.style.display = 'block';
                    setTimeout(() => { overlay.style.display = 'none'; }, 2000);
                    playPrizeSound(1000, true);
                } else if (anyPrize) {
                    playPrizeSound(100, false);
                } else {
                    playPrizeSound(0, false);
                }


                this.updateDisplay();
                this.resetScratchArea(`BATCH COMPLETED: ${cnt} TICKETS\n${anyMajor ? 'MAJOR WIN FOUND!' : ''}`);
            }


            updateDisplay() {
                this.els.statWin.innerText = `$${this.stats.totalWin.toLocaleString()}`;
                const remPoolTotal = this.isFinite ? (TOTAL_TICKETS - this.stats.scratched) : TOTAL_TICKETS;
                this.els.scratchedInfo.innerText = `${this.stats.scratched.toLocaleString()} / ${this.isFinite ? TOTAL_TICKETS.toLocaleString() : '∞'}`;
                let ev = 0;
                this.els.rulesGrid.innerHTML = "";
                RULES_CONFIG.forEach((r, i) => {
                    const rem = this.isFinite ? (r.baseCount - this.stats.ruleCounts[i]) : r.baseCount;
                    const prob = remPoolTotal > 0 ? (rem / remPoolTotal) : (this.isFinite ? 0 : r.baseCount/TOTAL_TICKETS);
                    ev += (r.win * prob);
                    if (r.isPrize) {
                        const card = document.createElement('div');
                        card.className = "comic-panel p-4 flex flex-col justify-between h-full bg-white";
                        card.innerHTML = `<div><span class="px-1.5 py-0.5 border-2 border-black font-black text-[8px] uppercase" style="background:${r.color}">${r.name_en}</span><p class="text-xl font-black italic text-slate-900 mt-2">$${r.win.toLocaleString()}</p></div><div class="border-t-2 border-black pt-2 flex justify-between items-center"><span class="text-sm font-black text-indigo-600">${(prob*100).toFixed(4)}%</span>${this.isFinite ? `<span class="text-[10px] text-slate-400">#${rem.toLocaleString()}</span>` : ''}</div>`;
                        this.els.rulesGrid.appendChild(card);
                    }
                });
                this.els.prizeEv.innerText = `$${ev.toFixed(1)}`;
                const profitEv = ev - TICKET_PRICE;
                this.els.profitEv.innerText = `${profitEv >= 0 ? '+' : ''}$${profitEv.toFixed(1)}`;
                this.els.profitEv.style.color = profitEv >= 0 ? '#10b981' : '#f43f5e';
               
                const exp = this.stats.totalExpectedIncome;
                this.els.statExpected.innerText = `${exp >= 0 ? '+' : ''}$${Math.round(exp).toLocaleString()}`;
                this.els.statExpected.style.color = exp >= 0 ? '#10b981' : '#f43f5e';
               
                const profit = this.stats.totalWin - this.stats.totalCost;
                this.els.statProfit.innerText = `${profit >= 0 ? '+' : ''}$${profit.toLocaleString()}`;
                this.els.statProfit.style.color = profit >= 0 ? '#10b981' : '#f43f5e';
               
                if (this.walletEnabled) {
                    const bal = this.startingCapital + profit; this.els.statBalance.innerText = `$${bal.toLocaleString()}`;
                    if (bal < TICKET_PRICE && !this.isPurchased) {
                        this.els.buyBtn.disabled = true; this.els.buyBtn.innerText = "OUT OF CASH!";
                    } else if (!this.isPurchased) {
                        this.els.buyBtn.disabled = false; this.els.buyBtn.innerHTML = `BUY TICKET! <span class="block text-[10px] opacity-70 mt-1">$${TICKET_PRICE}</span>`;
                    }
                }
                if(this.chart) {
                    this.chart.data.datasets[0].data = RULES_CONFIG.map((r, i) => this.isFinite ? (r.baseCount - this.stats.ruleCounts[i]) : r.baseCount);
                    this.chart.update();
                }
            }


            showChartHighlight(idx) {
                const r = RULES_CONFIG[idx]; const prob = (this.lastRuleAtScratch / this.lastTotalAtScratch) * 100;
                this.els.overlay.classList.add('active'); this.els.overlay.style.backgroundColor = r.color + "44";
                this.els.overlay.querySelector('.overlay-category').innerText = r.name_en;
                this.els.overlay.querySelector('.overlay-win').innerText = r.win > 0 ? `WIN $${r.win.toLocaleString()}` : "MISS";
                this.els.overlay.querySelector('.overlay-math').innerText = `P=${prob.toFixed(4)}%`;
            }


            clearChartEffect() { this.els.overlay.classList.remove('active'); }
            resetScratchArea(t) {
                this.isPurchased = false; this.isScratched = false; this.els.buyBtn.disabled = false; this.els.grid.classList.add('grayscale');
                this.ctx.fillStyle = '#1e293b'; this.ctx.fillRect(0,0,660,460); this.ctx.fillStyle = "#fff"; this.ctx.font = "900 32px 'Noto Sans TC'"; this.ctx.textAlign = "center";
                t.split('\n').forEach((line, i) => { this.ctx.fillText(line, 330, 215 + (i * 50)); });
                this.els.msg.innerText = ""; this.clearChartEffect(); this.updateDisplay();
            }
        }


        function switchTab(t) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.getElementById(t).classList.add('active');
            document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('nav-' + t)?.classList.add('active');
            if (t === 'hall') loadHallOfFame();
        }


        let currentMajorPrize = null;
        function showWinnerModal(prize) {
            currentMajorPrize = prize;
            const submitBtn = document.getElementById('submit-winner-btn');
            submitBtn.disabled = false;
            submitBtn.innerText = "登錄風雲榜 🚀";
            document.getElementById('winner-modal').style.display = 'flex';
        }


        document.getElementById('submit-winner-btn').onclick = async function() {
            const submitBtn = this;
            if (submitBtn.disabled) return; // 二重防護
           
            const nameInput = document.getElementById('winner-name').value.trim();
            const name = nameInput || "匿名幸運兒";
           
            if (!currentMajorPrize || !window.fb) return;


            // 立即禁用按鈕，防止多次點擊
            submitBtn.disabled = true;
            submitBtn.innerText = "正在傳送紀錄... 📡";


            try {
                const { db, collection, addDoc, serverTimestamp, appId } = window.fb;
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'hall_of_fame'), {
                    userName: name,
                    prizeName: currentMajorPrize.name_zh,
                    prizeEn: currentMajorPrize.name_en,
                    winAmount: currentMajorPrize.win,
                    color: currentMajorPrize.color,
                    timestamp: serverTimestamp()
                });
               
                // 成功後隱藏
                document.getElementById('winner-modal').style.display = 'none';
                document.getElementById('winner-name').value = "";
                switchTab('hall');
            } catch (e) {
                console.error("Upload failed", e);
                // 如果失敗，恢復按鈕讓玩家重試
                submitBtn.disabled = false;
                submitBtn.innerText = "重試登錄 🚀";
            }
        };


        function loadHallOfFame() {
            if (!window.fb) return;
            const { db, collection, onSnapshot, query, orderBy, appId } = window.fb;
            const q = query(collection(db, 'artifacts', appId, 'public', 'data', 'hall_of_fame'), orderBy('timestamp', 'desc'));
           
            onSnapshot(q, (snapshot) => {
                const listEl = document.getElementById('hall-list');
                listEl.innerHTML = "";
               
                if (snapshot.empty) {
                    listEl.innerHTML = `<div class="comic-panel p-10 flex items-center justify-center col-span-full bg-slate-50"><p class="text-2xl font-black uppercase text-slate-400">目前尚無傳奇紀錄，等您來刮！</p></div>`;
                    return;
                }


                snapshot.forEach((doc) => {
                    const data = doc.data();
                    const date = data.timestamp ? new Date(data.timestamp.seconds * 1000).toLocaleDateString() : 'Just Now';
                    const card = document.createElement('div');
                    card.className = "comic-panel p-6 bg-white transform hover:scale-105 transition-transform";
                    if (data.prizeEn.includes('JACKPOT')) card.classList.add('ring-4', 'ring-yellow-400', 'ring-offset-4');
                   
                    card.innerHTML = `
                        <div class="flex justify-between items-start mb-4">
                            <span class="bg-black text-white px-2 py-1 text-[10px] font-black uppercase tracking-widest">${date}</span>
                            <span class="text-xl font-black italic" style="color:${data.color}">$${data.winAmount.toLocaleString()}</span>
                        </div>
                        <h4 class="text-2xl font-black italic mb-1 truncate">${data.userName}</h4>
                        <p class="text-xs font-black text-slate-500 uppercase border-t-2 border-black pt-2">${data.prizeEn}</p>
                    `;
                    listEl.appendChild(card);
                });
            }, (err) => console.error("Snapshot error", err));
        }


        window.onload = () => {
            window.simIndie = new ScratchSimulator('independent', false);
            window.simFinite = new ScratchSimulator('finite', true);
            switchTab('independent');
        };
    </script>
